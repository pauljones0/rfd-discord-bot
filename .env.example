# Required
DISCORD_APP_ID=your-app-id
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_PUBLIC_KEY=your-public-key
RFD_ADMIN_TOKEN=change-me-to-a-long-random-token
# Optional separate token accepted only by POST /ingest/discord-notification.
# If unset, configure the listener with RFD_ADMIN_TOKEN instead.
SWORDSWALLOWER_SECRET=
ALLOW_UNSIGNED_DISCORD_INTERACTIONS=false
# Comma-separated list of Gemini API keys for quota rotation.
# Multiple keys are rotated on quota exhaustion (each key has independent daily limits).
GEMINI_API_KEY=your-gemini-key1,your-gemini-key2,your-gemini-key3
DATABASE_URL=postgres://rfd_bot:your-postgres-password@postgres:5432/rfd_discord_bot?sslmode=disable
POSTGRES_PASSWORD=your-postgres-password

# Optional: eBay API (disabled if not set)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-secret

# Optional: built-in local scheduler
LOCAL_SCHEDULER_ENABLED=false
RFD_POLL_INTERVAL=3m
EBAY_POLL_INTERVAL=30m
MEMEXPRESS_POLL_INTERVAL=30m
BESTBUY_POLL_INTERVAL=30m

# Optional feature gates. Disabled by default unless explicitly configured.
FACEBOOK_ENABLED=false
HARDWARESWAP_ENABLED=false

# Ordered low-cost scraper fallback lists. Paid adapters require explicit enable flags.
EBAY_COUPON_BACKENDS=http,external-stealth,camoufox,ai-crawler,paid-trial
MEMEXPRESS_BACKENDS=http,external-stealth,camoufox,ai-crawler,paid-trial
BESTBUY_BACKENDS=bestbuy-algolia,http
BESTBUY_COMPUTE_SOLD_VERIFY_ENABLED=true
BESTBUY_COMPUTE_SOLD_QUERY_DELAY=3s
BESTBUY_COMPUTE_SOLD_PAID_BROWSER_ENABLED=false
BESTBUY_COMPUTE_SOLD_PAID_BROWSER_MAX_CALLS_PER_RUN=0
BESTBUY_COMPUTE_SOLD_PAID_BROWSER_MAX_CALLS_PER_DAY=0
BESTBUY_SOLD_COMPS_ENABLED=true
BESTBUY_SOLD_COMP_BACKENDS=http,external-stealth,camoufox,ai-crawler
BESTBUY_SOLD_COMP_CACHE_TTL=24h
BESTBUY_SOLD_COMP_QUERY_DELAY=3s
BESTBUY_SOLD_COMP_MAX_PER_RUN=10
BESTBUY_SOLD_COMP_PAID_BROWSER_ENABLED=false
BESTBUY_SOLD_COMP_PAID_BROWSER_MAX_CALLS_PER_RUN=0
BESTBUY_SOLD_COMP_PAID_BROWSER_MAX_CALLS_PER_DAY=0
PY_BROWSER_PACKAGE_REFRESH=latest
# Set INSTALL_CAMOUFOX_BROWSER=true only when building an image with a baked-in Camoufox browser.
INSTALL_CAMOUFOX_BROWSER=false
INSTALL_PLAYWRIGHT_BROWSERS=false
SCRAPELAB_AUTO_INSTALL_BROWSERS=true
RFD_BOT_BROWSER_CACHE_DIR=/srv/appdata/rfd-discord-bot/browser-cache

# Command adapters use JSON argv arrays. {url} is replaced only when it is a full argv value.
# Legacy *_COMMAND shell strings still work temporarily with a warning, but should not be used for new deploys.
SCRAPELAB_EXTERNAL_STEALTH_COMMAND_ARGS=["python","scripts/nodriver_fetch.py","{url}","--profile-dir",".codex-remote/nodriver-profile","--headless","--wait-seconds","7"]
SCRAPELAB_CAMOUFOX_COMMAND_ARGS=["python","scripts/camoufox_fetch.py","{url}","--headless","--wait-ms","7000"]
SCRAPELAB_AI_CRAWLER_COMMAND_ARGS=["python","scripts/crawl4ai_fetch.py","{url}","--headless","--wait-ms","7000"]
EBAY_COUPON_EXTERNAL_STEALTH_COMMAND_ARGS=["python","scripts/nodriver_fetch.py","{url}","--profile-dir",".codex-remote/nodriver-profile","--headless","--wait-seconds","7"]
EBAY_COUPON_CAMOUFOX_COMMAND_ARGS=["python","scripts/camoufox_fetch.py","{url}","--headless","--wait-ms","7000"]
EBAY_COUPON_AI_CRAWLER_COMMAND_ARGS=["python","scripts/crawl4ai_fetch.py","{url}","--headless","--wait-ms","7000"]
EBAY_PAID_BROWSER_ENABLED=false
EBAY_PAID_BROWSER_MAX_CALLS_PER_RUN=1
EBAY_PAID_BROWSER_MAX_CALLS_PER_DAY=6
MEMEXPRESS_PAID_BROWSER_ENABLED=false
MEMEXPRESS_PAID_BROWSER_MAX_CALLS_PER_RUN=0
MEMEXPRESS_PAID_BROWSER_MAX_CALLS_PER_DAY=0
# BROWSERLESS_TOKEN=your-browserless-token
# EBAY_COUPON_PAID_TRIAL_COMMAND_ARGS=["/opt/scrape-venv/bin/python","scripts/browserless_bql_fetch.py","{url}","--wait-ms","5000"]

# Optional: Evomi Residential Proxy (recommended for Facebook Marketplace scraping)
# Targeting params (country, city, session) are appended automatically.
PROXY_URL=http://user:pass@core-residential.evomi.com:1000

# Optional: Logging
# LOG_LEVEL=INFO

# Optional: Gemini regions (comma-separated)
# GEMINI_LOCATIONS=us-central1,us-east4,us-west1

# Optional: X/Twitter API credentials for auto-posting OnEveryCorner goal alerts
# (in conjunction with Discord notifications). Supports up to two accounts.
# Use the 4 OAuth 1.0a User Context keys from https://developer.x.com (app with Read+Write).
X_API_KEY=your-consumer-key
X_API_KEY_SECRET=your-consumer-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret

# Second account (optional)
X2_API_KEY=...
X2_API_KEY_SECRET=...
X2_ACCESS_TOKEN=...
X2_ACCESS_TOKEN_SECRET=...
