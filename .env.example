# Required
GOOGLE_CLOUD_PROJECT=your-project-id
DISCORD_APP_ID=your-app-id
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_PUBLIC_KEY=your-public-key
GEMINI_API_KEY=your-gemini-key

# Optional: eBay API (disabled if not set)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-secret

# Optional: ProxyScrape Residential Proxy (required for Facebook Marketplace scraping)
# Full URL format:
PROXY_URL=http://user:pass@rp.scrapegw.com:6060
# OR individual components:
# PROXY_HOST=rp.scrapegw.com
# PROXY_PORT=6060
# PROXY_USER=vit9171kplof53i-country-ca
# PROXY_PASS=your_password_here

# Optional: Logging
# LOG_LEVEL=INFO

# Optional: Gemini regions (comma-separated)
# GEMINI_LOCATIONS=us-central1,us-east4,us-west1
