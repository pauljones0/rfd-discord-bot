# Required
DISCORD_APP_ID=your-app-id
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_PUBLIC_KEY=your-public-key
# Comma-separated list of Gemini API keys for quota rotation.
# Multiple keys are rotated on quota exhaustion (each key has independent daily limits).
GEMINI_API_KEY=your-gemini-key1,your-gemini-key2,your-gemini-key3
DATABASE_URL=postgres://rfd_bot:your-postgres-password@postgres:5432/rfd_discord_bot?sslmode=disable
POSTGRES_PASSWORD=your-postgres-password

# Optional: eBay API (disabled if not set)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-secret

# Optional: built-in local scheduler
LOCAL_SCHEDULER_ENABLED=false
RFD_POLL_INTERVAL=3m
EBAY_POLL_INTERVAL=30m
MEMEXPRESS_POLL_INTERVAL=30m
BESTBUY_POLL_INTERVAL=30m

# Optional feature gates
FACEBOOK_ENABLED=false
HARDWARESWAP_ENABLED=false

# Ordered low-cost scraper fallback lists. Paid adapters require explicit enable flags.
EBAY_COUPON_BACKENDS=http,external-stealth,camoufox,ai-crawler,paid-trial
MEMEXPRESS_BACKENDS=http,external-stealth,camoufox,ai-crawler,paid-trial
BESTBUY_BACKENDS=bestbuy-algolia,http
SCRAPELAB_EXTERNAL_STEALTH_COMMAND=python scripts/nodriver_fetch.py "{url}" --profile-dir .codex-remote/nodriver-profile --headless --wait-seconds 7
SCRAPELAB_CAMOUFOX_COMMAND=python scripts/camoufox_fetch.py "{url}" --headless --wait-ms 7000
SCRAPELAB_AI_CRAWLER_COMMAND=python scripts/crawl4ai_fetch.py "{url}" --headless --wait-ms 7000
EBAY_COUPON_EXTERNAL_STEALTH_COMMAND=python scripts/nodriver_fetch.py "{url}" --profile-dir .codex-remote/nodriver-profile --headless --wait-seconds 7
EBAY_COUPON_CAMOUFOX_COMMAND=python scripts/camoufox_fetch.py "{url}" --headless --wait-ms 7000
EBAY_COUPON_AI_CRAWLER_COMMAND=python scripts/crawl4ai_fetch.py "{url}" --headless --wait-ms 7000
EBAY_PAID_BROWSER_ENABLED=false
MEMEXPRESS_PAID_BROWSER_ENABLED=false
# BROWSERLESS_TOKEN=your-browserless-token
# EBAY_COUPON_PAID_TRIAL_COMMAND=/opt/scrape-venv/bin/python scripts/browserless_bql_fetch.py "{url}" --wait-ms 5000

# Optional: Evomi Residential Proxy (recommended for Facebook Marketplace scraping)
# Targeting params (country, city, session) are appended automatically.
PROXY_URL=http://user:pass@core-residential.evomi.com:1000

# Optional: Logging
# LOG_LEVEL=INFO

# Optional: Gemini regions (comma-separated)
# GEMINI_LOCATIONS=us-central1,us-east4,us-west1
