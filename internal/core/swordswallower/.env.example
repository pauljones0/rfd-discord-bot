# Webhook URL from the Android emulator back to rfd-discord-bot.
SWORDSWALLOWER_WEBHOOK=http://10.0.2.2:8787/ingest/discord-notification

# Optional shared secret accepted by rfd-discord-bot only for the ingest route.
# If unset, configure the listener with RFD_ADMIN_TOKEN instead.
SWORDSWALLOWER_SECRET=
RFD_ADMIN_TOKEN=use-rfd-admin-token-here

# Optional receiver sidecar target on the rfd-discord-bot Docker network.
FORWARD_URL=http://rfd-discord-bot:8080/ingest/discord-notification
FORWARD_BEARER_TOKEN=use-rfd-admin-token-here
FORWARD_TIMEOUT=5

# Optional path to a user-supplied Discord APK, or a directory of split APKs.
DISCORD_APK=/path/to/discord.apk
